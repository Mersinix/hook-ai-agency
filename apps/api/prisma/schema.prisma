generator client {
 provider = "prisma-client-js"
}

datasource db {
 provider = "postgresql"
 url      = env("DATABASE_URL")
}

/////////////////////////////////////////////////
// ENUMS
/////////////////////////////////////////////////

enum Locale {
 fr
 en
}

enum LeadStatus {
 NEW
 CONTACTED
 QUALIFIED
 WON
 LOST
}

enum UserRole {
 ADMIN
 MEMBER
}

enum AIRequestType {
 SEO
 STRATEGY
 AUDIT
 COPYWRITING
 AUTOMATION
 SGO
 OTHER
}

enum ServiceCategory {
 GROWTH
 CREATIVE
 BUILD
 AUTOMATE
}

enum CaseStudyType {
 GROWTH_SYSTEM
 AUTOMATION
 PLATFORM
 CREATIVE_CAMPAIGN
}

enum ProjectStatus {
 FEATURED
 ACTIVE
 ARCHIVED
}

/////////////////////////////////////////////////
// USERS
/////////////////////////////////////////////////

model User {
 id String @id @default(cuid())

 email String @unique
 password String
 name String?

 role UserRole @default(ADMIN)

 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
}

/////////////////////////////////////////////////
// SERVICES
/////////////////////////////////////////////////

model Service {
 id String @id @default(cuid())

 slug String @unique

 name_fr String
 name_en String

 description_fr String?
 description_en String?

 category ServiceCategory

 icon String?
 featured Boolean @default(false)

 /////////////////////////////////////////////////
 // Relations
 /////////////////////////////////////////////////

 industries IndustryService[]

 caseStudies CaseStudyService[]

 leadSelections LeadService[]

 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
}

/////////////////////////////////////////////////
// INDUSTRIES
/////////////////////////////////////////////////

model Industry {
 id String @id @default(cuid())

 slug String @unique

 name_fr String
 name_en String

 description_fr String?
 description_en String?

 icon String?

 subIndustries SubIndustry[]

 /////////////////////////////////////////////////
 // Relations
 /////////////////////////////////////////////////

 services IndustryService[]

 caseStudies CaseStudy[]

 leadSelections LeadIndustry[]

 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
}

/////////////////////////////////////////////////
// SERVICE x INDUSTRY SOLUTIONS
/////////////////////////////////////////////////

model IndustryService {
 id String @id @default(cuid())

 industryId String
 serviceId String

 solutionTitle String?
 solutionDescription String?

 industry Industry @relation(fields:[industryId], references:[id], onDelete: Cascade)

 service Service @relation(fields:[serviceId], references:[id], onDelete: Cascade)

 @@unique([industryId, serviceId])
}

/////////////////////////////////////////////////
// SUB INDUSTRIES
/////////////////////////////////////////////////

model SubIndustry {
 id String @id @default(cuid())

 slug String

 name_fr String
 name_en String

 description_fr String?
 description_en String?

 industryId String

 industry Industry @relation(fields:[industryId], references:[id], onDelete: Cascade)

 templates Template[]

 leads Lead[]

 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
}

/////////////////////////////////////////////////
// TEMPLATES
/////////////////////////////////////////////////

model Template {
 id String @id @default(cuid())

 title_fr String
 title_en String

 description_fr String?
 description_en String?

 previewImage String?
 demoUrl String?

 sections Json

 isActive Boolean @default(true)

 subIndustryId String

 subIndustry SubIndustry @relation(fields:[subIndustryId], references:[id], onDelete: Cascade)

 views TemplateView[]

 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
}

/////////////////////////////////////////////////
// GROWTH SYSTEMS / CASE STUDIES
/////////////////////////////////////////////////

model CaseStudy {
 id String @id @default(cuid())

 slug String @unique

 title String

 headline String?

 description String

 type CaseStudyType

 status ProjectStatus @default(FEATURED)

 metricValue String?
 metricLabel String?

 imageUrl String?

 stack Json?

 featured Boolean @default(true)

 industryId String?

 industry Industry? @relation(fields:[industryId], references:[id], onDelete: SetNull)

 services CaseStudyService[]

 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
}

model CaseStudyService {
 id String @id @default(cuid())

 caseStudyId String
 serviceId String

 caseStudy CaseStudy @relation(fields:[caseStudyId], references:[id], onDelete: Cascade)

 service Service @relation(fields:[serviceId], references:[id], onDelete: Cascade)

 @@unique([caseStudyId, serviceId])
}

/////////////////////////////////////////////////
// LEADS
/////////////////////////////////////////////////

model Lead {
 id String @id @default(cuid())

 fullName String
 email String
 phone String?

 company String?
 message String?

 budgetRange String?

 source String?

 subIndustryId String?

 status LeadStatus @default(NEW)

 subIndustry SubIndustry? @relation(fields:[subIndustryId], references:[id], onDelete: SetNull)

 /////////////////////////////////////////////////
 // MULTI SELECT PICKLIST RELATIONS
 /////////////////////////////////////////////////

 services LeadService[]

 industries LeadIndustry[]

 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt

 @@index([status])
 @@index([subIndustryId])
}

/////////////////////////////////////////////////
// LEAD x SERVICES (MULTI SELECT)
/////////////////////////////////////////////////

model LeadService {
 id String @id @default(cuid())

 leadId String
 serviceId String

 lead Lead @relation(fields:[leadId], references:[id], onDelete: Cascade)

 service Service @relation(fields:[serviceId], references:[id], onDelete: Cascade)

 @@unique([leadId, serviceId])
}

/////////////////////////////////////////////////
// LEAD x INDUSTRIES (MULTI SELECT)
/////////////////////////////////////////////////

model LeadIndustry {
 id String @id @default(cuid())

 leadId String
 industryId String

 lead Lead @relation(fields:[leadId], references:[id], onDelete: Cascade)

 industry Industry @relation(fields:[industryId], references:[id], onDelete: Cascade)

 @@unique([leadId, industryId])
}

/////////////////////////////////////////////////
// TESTIMONIALS
/////////////////////////////////////////////////

model Testimonial {
 id String @id @default(cuid())

 quote String
 author String
 role String
 avatar String?
 stars Int @default(5)

 isPublished Boolean @default(true)
 sortOrder Int @default(0)

 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
}

/////////////////////////////////////////////////
// FAQ
/////////////////////////////////////////////////

model FAQ {
 id String @id @default(cuid())

 question String
 answer String

 isPublished Boolean @default(true)
 sortOrder Int @default(0)

 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
}

/////////////////////////////////////////////////
// AI REQUESTS
/////////////////////////////////////////////////

model AIRequest {
 id String @id @default(cuid())

 prompt String

 response String?

 type AIRequestType

 metadata Json?

 createdAt DateTime @default(now())
}

/////////////////////////////////////////////////
// ANALYTICS
/////////////////////////////////////////////////

model AnalyticsEvent {
 id String @id @default(cuid())

 eventName String

 payload Json?

 userId String?

 createdAt DateTime @default(now())
}

/////////////////////////////////////////////////
// TEMPLATE VIEWS
/////////////////////////////////////////////////

model TemplateView {
 id String @id @default(cuid())

 templateId String

 template Template @relation(fields:[templateId], references:[id], onDelete: Cascade)

 ip String?
 userAgent String?

 createdAt DateTime @default(now())

 @@index([templateId])
}